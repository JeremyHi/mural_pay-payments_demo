# Mural Pay API Configuration
MURAL_API_KEY=your-api-key-here
MURAL_TRANSFER_API_KEY=your-transfer-api-key-here
MURAL_ORGANIZATION_ID=your-organization-id
MURAL_ACCOUNT_ID=your-account-id
MURAL_COUNTERPARTY_ID=your-counterparty-id
MURAL_PAYOUT_METHOD_ID=your-payout-method-id
MURAL_API_BASE_URL=https://api-staging.muralpay.com

# Webhook Security
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_PUBLIC_KEY=your-webhook-public-key

# Supabase Database
# Get your connection string from: https://supabase.com/dashboard/project/[project-ref]/settings/database
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional: Supabase Client (if using Supabase client library)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
